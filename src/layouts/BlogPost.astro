---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Navigation from "../components/Navigation.astro";
import ParentPost from "../components/ParentPost.astro";
import ChildPosts from "../components/ChildPosts.astro";
import RelatedPosts from "../components/RelatedPosts.astro";
import BreadcrumbSchema from "../components/BreadcrumbSchema.astro";
import { SITE_TITLE } from "../config";

export interface Props {
    content: {
        title: string;
        description: string;
        pubDate?: string;
        updatedDate?: string;
        tags?: string[];
        url?: string;
        author?: string;
    };
}

const {
    content: {
        url,
        title,
        description,
        pubDate,
        updatedDate,
        tags = [],
        author = "Lucas Sifoni",
        childPostsTitle,
    },
} = Astro.props;

// Generate canonical URL
const canonicalURL = url ? new URL(url, Astro.site) : Astro.url;

// Breadcrumb items for blog posts
const breadcrumbItems = [
    { name: "Home", url: "/" },
    { name: "Blog", url: "/blog" },
    { name: title, url: canonicalURL.pathname },
];

const NEWSLETTER_FORMS = {
    elixir: {
        href: "https://fda0e546.sibforms.com/serve/MUIFAJTN6nTgQVcag39026SctPFkI68M9chZWELrJgsezqA_OCR8PmS9I3I71GV4a__jH7xcSMHfRIIN84_007LSiVw9uuFGF9odrqxHXOP6ohQ61PPqC-9oqWtwEIFiK1r-7COh7LAku-81f0t3nknqnL-UNgEYqvcMY7gAjnJCw4avG7nC2TBpvC_uEmsx9Kvr2xYO39O5eH65",
        intro:
            "You can be notified of new Elixir posts (and only Elixir posts) by subscribing to my newsletter.",
    },
    astronomy: {
        href: "https://fda0e546.sibforms.com/serve/MUIFAAnbWSa9_5rUBkuEYQpginHHl1W6SiNNsdo9baHkYd44o0yQwnMAK-oHG5pNC0sXyDoGdNqhiGOIsFrdylkvuIUXSofOTsEIg9XByNzn20cKhzyQSTlnJGtqaEm8ZCDb7eySybx9j2X6tSbm5-io3uIPmJ1LJ4XpePXyMIzz6x8gRvGutniFoaNtyWlf5h1Ax_OGn47V4pAG",
        intro:
            "You can be notified of new astronomy posts (and only astronomy posts) by subscribing to my newsletter.",
    },
};

const newsletter =
    (tags.includes("elixir") && NEWSLETTER_FORMS.elixir) ||
    (tags.includes("astronomy") && NEWSLETTER_FORMS.astronomy) ||
    null;
---

<html lang="en">
    <head>
        <BaseHead
            title={SITE_TITLE + " - " + title}
            description={description}
            canonical={canonicalURL.pathname}
            publishDate={pubDate}
            modifiedDate={updatedDate}
            type="article"
            tags={tags}
            author={author}
        />
        <BreadcrumbSchema items={breadcrumbItems} />
        <style>
            .title {
                font-size: 2.4em;
                margin: 0.5em 0;
                font-weight: normal;
                max-width: 28ch;
                line-height: 1.2;
            }
            hr {
                margin: 1rem 0;
            }
            .footer_additions ul,
            li {
                display: inline;
                margin: 0;
                padding: 0;
            }
            .footer_additions li::after {
                content: " / ";
            }
            .footer_additions li.noslash::after {
                content: "";
            }
            .footer_additions li:last-child::after {
                content: "";
            }
            .elixir-cta {
                margin: 0 0 1.4rem;
                padding: 0 0 0.9rem;
                border-bottom: 1px dotted gray;
                font-size: 0.8em;
            }
            .elixir-cta p {
                margin: 0;
            }
            .newsletter-cta {
                margin: 2.5rem 0 0;
                padding: 1rem 0;
                border-top: 1px dotted var(--ink);
                border-bottom: none;
                max-width: 65ch;
                font-size: 0.9em;
            }
            .newsletter-cta p {
                margin: 0 0 0.7rem;
                max-width: none;
            }
            .newsletter-cta__btn {
                display: inline-block;
                border: 1px dotted var(--ink);
                border-radius: 4px;
                padding: 4px 12px;
                text-decoration: none;
            }
            .newsletter-cta__btn:hover {
                background: var(--ink);
                color: #fff;
            }
        </style>
    </head>

    <body>
        <Header have_langs={false} />
        <main style="margin-top: 2em;">
            <article>

                <h1 class="title" set:html={title.replace("--", "<br/>")} />
                {
                    (tags || []).length && (
                        <div
                            class="tags-container"
                            style="margin-bottom: .75em;"
                        >
                            <div class="tags">
                                {(tags || []).map((t) => (
                                    <a href={"/blog/tag/" + t}>
                                        <span class={"tag " + t}>{t}</span>
                                    </a>
                                ))}
                            </div>
                        </div>
                    )
                }
                {pubDate && <time style="font-size: 0.7rem">{pubDate}</time>}

                {
                    updatedDate && (
                        <div>
                            Last updated on <time>{updatedDate}</time>
                        </div>
                    )
                }
                <Navigation me={url} />
                <hr />
                {
                    (tags || []).includes("elixir") && (
                        <aside class="elixir-cta">
                            <p>
                                Working on something in Elixir or on the BEAM
                                where a fresh pair of eyes would help ? I take
                                on a couple of days a week for consulting work
                                : library design, structure review,
                                exploratory prototypes...<br/>
                                <a href="/hire">See how I can help &rarr;</a>
                            </p>
                        </aside>
                    )
                }
                <ParentPost currentUrl={url} />
                <slot />
                {
                    newsletter && (
                        <aside class="newsletter-cta">
                            <p>{newsletter.intro}</p>
                            <a
                                class="newsletter-cta__btn"
                                href={newsletter.href}
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                Subscribe &rarr;
                            </a>
                        </aside>
                    )
                }
            </article>


            <ChildPosts parentUrl={url} title={childPostsTitle} />

            {
                (tags || []).length > 0 && (
                    <RelatedPosts
                        currentTags={tags || []}
                        currentUrl={url}
                        minCommonTags={1}
                    />
                )
            }
        </main>
        <Footer />
    </body>
</html>
